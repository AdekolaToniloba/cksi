generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  password      String?
  emailVerified DateTime?
  image         String?
  role          Role       @default(USER)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  blogPosts     BlogPost[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BlogPost {
  id            String     @id @default(cuid())
  title         String
  slug          String     @unique
  excerpt       String
  content       String
  category      String
  tags          String[]
  imageUrl      String?
  authorId      String
  publishedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  status        PostStatus @default(DRAFT)
  imagePublicId String?    @map("image_public_id")
  isFeatured    Boolean    @default(false)
  author        User       @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([isFeatured])
}

model HeroCarousel {
  id           String    @id @default(cuid())
  title        String
  description  String
  ctaText      String
  ctaLink      String
  mediaUrl     String
  mediaType    MediaType @default(IMAGE)
  cloudinaryId String?
  orderIndex   Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([orderIndex])
  @@index([isActive])
}

model Program {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  description   String
  category      String
  beneficiaries String
  location      String
  duration      String
  startDate     DateTime
  status        ProgramStatus @default(ACTIVE)
  progress      Int?
  goal          String
  achievements  String[]
  imageUrl      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([slug])
  @@index([status])
}

model GalleryEvent {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  description String?
  category    String
  location    String?
  eventDate   DateTime?
  coverImage  String?
  isPublished Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  mediaItems  GalleryMedia[]

  @@index([category])
  @@index([slug])
}

model GalleryMedia {
  id                 String       @id @default(cuid())
  eventId            String
  title              String?
  description        String?
  mediaUrl           String
  mediaType          MediaType    @default(IMAGE)
  fileSize           Int?
  mimeType           String?
  width              Int?
  height             Int?
  duration           Int?
  orderIndex         Int          @default(0)
  isPublished        Boolean      @default(true)
  cloudinaryPublicId String?
  cloudinaryFolder   String?
  cloudinaryVersion  String?
  cloudinaryFormat   String?
  cloudinaryTags     String[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  event              GalleryEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([mediaType])
  @@index([cloudinaryPublicId])
}

model Volunteer {
  id             String            @id @default(cuid())
  name           String
  email          String
  phone          String
  state          String
  country        String
  capacity       VolunteerCapacity
  additionalHelp String
  receiveUpdates Boolean           @default(false)
  status         VolunteerStatus   @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([email])
  @@index([status])
  @@index([capacity])
  @@index([createdAt])
}

model Donation {
  id                String         @id @default(cuid())
  donorName         String?
  donorEmail        String
  donorPhone        String?
  amount            Float
  currency          String         @default("NGN")
  campaignId        String?
  paymentReference  String         @unique
  paystackReference String?
  status            DonationStatus @default(PENDING)
  isAnonymous       Boolean        @default(false)
  donationType      DonationType   @default(ONE_TIME)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([donorEmail])
  @@index([status])
}

model HomepageContent {
  id         String   @id @default(cuid())
  section    String
  title      String?
  content    String?
  orderIndex Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum MediaType {
  IMAGE
  VIDEO
}

enum VolunteerCapacity {
  TEACHING
  HEALTHCARE
  MENTORSHIP
  FUNDRAISING
  EVENT_PLANNING
  TECHNOLOGY
  ADMINISTRATION
  COMMUNITY_OUTREACH
  SKILLED_LABOR
  OTHER
}

enum VolunteerStatus {
  PENDING
  REVIEWED
  APPROVED
  CONTACTED
  DECLINED
}

enum Role {
  USER
  ADMIN
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum ProgramStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
}

enum DonationType {
  ONE_TIME
  MONTHLY
}
